   "source": [
    "df[\"fuel\"] = df[\"fuel\"].apply(lambda x: \n",
    "    \"CNG\" if \"CNG\" in x else\n",
    "    \"Electric\" if \"Electric\" in x else\n",
    "    \"Hybrid\" if \"Hybrid\" in x else\n",
    "    x\n",
    ")"
   ]
  },
