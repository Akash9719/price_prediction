   "source": [
    "#Run Evalution\n",
    "\n",
    "print(\"Random Forest:\")\n",
    "evaluate(rf_pipeline, X_test, y_test)\n",
    "\n",
    "print(\"\\nXGBoost:\")\n",
    "evaluate(xgb_pipeline, X_test, y_test)"
   ]
