   "source": [
    "#Train Model\n",
    "\n",
    "rf_pipeline.fit(X_train, y_train)\n",
    "xgb_pipeline.fit(X_train, y_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 44,
   "id": "5c93cdab-f4a2-400b-b4b9-9a5ad724ad6d",
   "metadata": {},
   "outputs": [],
   "source": [
    "#define rules based evaluation\n",
    "\n",
    "def evaluate(model, X_test, y_test):\n",
    "    preds = model.predict(X_test)\n",
    "\n",
    "    # Convert back to ₹\n",
    "    y_actual = np.expm1(y_test)\n",
    "    preds_actual = np.expm1(preds)\n",
    "\n",
    "    print(\"\\nSample Actual Prices (₹):\", y_actual[:5])\n",
    "    print(\"Sample Predicted Prices (₹):\", preds_actual[:5])\n",
    "\n",
    "    mae = mean_absolute_error(y_actual, preds_actual)\n",
    "    rmse = np.sqrt(mean_squared_error(y_actual, preds_actual))\n",
    "    r2 = r2_score(y_actual, preds_actual)\n",
    "\n",
    "    print(\"MAE (₹):\", round(mae, 2))\n",
    "    print(\"RMSE (₹):\", round(rmse, 2))\n",
    "    print(\"R2 Score:\", round(r2, 4))"
   ]
  },
